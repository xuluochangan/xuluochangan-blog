---
import { Icon } from "astro-icon/components";

import WidgetLayout from "../common/WidgetLayout.astro";

interface Props {
	class?: string;
	style?: string;
}

const className = Astro.props.class;
const style = Astro.props.style;
const isTreeholePage = Astro.url.pathname.startsWith("/treehole");
---

{
	!isTreeholePage && (
		<WidgetLayout name="树洞" id="treehole-entry" class={className} style={style}>
			<p class="mb-3 text-sm leading-relaxed text-neutral-600 dark:text-neutral-300">
				有些话，可以只说给我听。
			</p>
			<a
				href="/treehole/"
				class="btn-regular flex items-center justify-center gap-2 rounded-lg px-3 py-2 text-sm font-medium active:scale-95 transition-transform"
			>
				<Icon name="material-symbols:forest-outline" class="text-base" />
				悄悄留言
			</a>
		</WidgetLayout>
	)
}
