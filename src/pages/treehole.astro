---
import TreeholeApp from "@components/features/treehole/TreeholeApp.svelte";
import MainGridLayout from "@layouts/MainGridLayout.astro";

export const prerender = true;
---

<MainGridLayout
	title="树洞"
	description="一处只有访客与站长能够看见的私人留言空间"
>
	<script>
		import("../scripts/right-sidebar-layout.js");
	</script>
	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-5 py-6 md:px-9 relative w-full">
			<header class="mb-8">
				<h1 class="treehole-title">树洞</h1>
				<p class="mt-2 text-black/60 dark:text-white/60">
					想说什么都可以。这里的每段对话，只属于你和我。
				</p>
			</header>
			<TreeholeApp client:only="svelte" />
		</div>
	</div>
</MainGridLayout>

<style>
	.treehole-title {
		position: relative;
		font-size: 2.25rem;
		font-weight: 700;
		line-height: 1.2;
		color: color-mix(in srgb, var(--content) 92%, transparent);
	}

	.treehole-title::before {
		content: "";
		position: absolute;
		top: 50%;
		left: -1rem;
		width: 0.25rem;
		height: 2rem;
		border-radius: 999px;
		background: var(--primary);
		transform: translateY(-50%);
	}
</style>
